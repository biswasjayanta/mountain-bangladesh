# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
node_report.csv
v8.log

# Directories for compiled output (Vite uses 'dist', Webpack often uses 'build' or 'dist')
dist
dist-ssr
build
out

# Dependencies (This is the big one!)
node_modules
jspm_packages

# Environment variables (Crucial for hiding your API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Optional: cache directories for frameworks/bundlers
.eslintcache
.stylelintcache
.vite
